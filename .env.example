# Provider names: openai, anthropic, gemini, ollama, custom
BIOPHARMA_LLM_PROVIDER=openai

# OpenAI-compatible providers, including OpenAI, Azure OpenAI-compatible gateways,
# vLLM, LM Studio, Together, DeepSeek-compatible endpoints, etc.
BIOPHARMA_LLM_BASE_URL=https://api.openai.com/v1
BIOPHARMA_LLM_API_KEY=change-me
BIOPHARMA_LLM_MODEL=gpt-4.1-mini

# Optional endpoint overrides for custom HTTP or self-hosted gateways.
BIOPHARMA_LLM_CHAT_PATH=/chat/completions
BIOPHARMA_LLM_EMBEDDING_PATH=/embeddings

# Runtime behavior.
BIOPHARMA_LLM_TIMEOUT_SECONDS=60
BIOPHARMA_LLM_TEMPERATURE=0.1
BIOPHARMA_LLM_MAX_TOKENS=4000

# Storage backend: jsonl or postgres. JSONL is the local default.
BIOPHARMA_STORAGE_BACKEND=jsonl
BIOPHARMA_ANALYSIS_JSONL_PATH=data/processed/insights.jsonl
BIOPHARMA_FEEDBACK_JSONL_PATH=data/feedback/reviews.jsonl

# Required only when BIOPHARMA_STORAGE_BACKEND=postgres.
# Matches compose.yaml by default.
BIOPHARMA_POSTGRES_DSN=postgresql://biopharma:biopharma@127.0.0.1:55432/biopharma_agent
BIOPHARMA_RUN_POSTGRES_TESTS=0

# Raw archive backend: local, s3, or minio.
BIOPHARMA_RAW_ARCHIVE_BACKEND=local
BIOPHARMA_RAW_ARCHIVE_PATH=data/raw

# Required only when BIOPHARMA_RAW_ARCHIVE_BACKEND=s3 or minio.
BIOPHARMA_RAW_ARCHIVE_S3_BUCKET=biopharma-raw
BIOPHARMA_RAW_ARCHIVE_S3_PREFIX=raw
BIOPHARMA_RAW_ARCHIVE_S3_ENDPOINT_URL=http://127.0.0.1:9000
BIOPHARMA_RAW_ARCHIVE_S3_REGION=us-east-1
BIOPHARMA_RAW_ARCHIVE_S3_ACCESS_KEY_ID=minioadmin
BIOPHARMA_RAW_ARCHIVE_S3_SECRET_ACCESS_KEY=minioadmin

# Optional Airflow wrapper settings.
BIOPHARMA_AIRFLOW_SOURCES="fda_press_releases biopharma_dive_news"
BIOPHARMA_AIRFLOW_LIMIT=2
BIOPHARMA_AIRFLOW_ANALYZE=0
BIOPHARMA_AIRFLOW_SCHEDULE="0 * * * *"
BIOPHARMA_AIRFLOW_RUN_LOG=data/runs/airflow_fetch_runs.jsonl
